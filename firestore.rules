rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Genesis Admin Check
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'skippergemx@gmail.com';
    }
    
    // ULTIMATE ADMIN OVERRIDE
    // Grants absolute read/write access to the entire database for maintenance
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // STANDARD PROTOCOLS: User-level access rules
    
    // Personal Profile Security
    match /artifacts/crystle-hunter-world-v1/users/{userEmail}/profile/data {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
    }
    
    // Leaderboard Security
    match /artifacts/crystle-hunter-world-v1/public/data/leaderboard/{userEmail} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.token.email == userEmail;
    }

    // PVP Room Security
    match /artifacts/crystle-hunter-world-v1/public/data/pvp_room/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // PVP Chat Security
    match /artifacts/crystle-hunter-world-v1/public/data/pvp_chat/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Marketplace Security
    match /artifacts/crystle-hunter-world-v1/public/data/marketplace/{listingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Marketplace Payouts (seller receives GX from buyers)
    // Any authenticated user can create a payout; recipients can delete theirs.
    match /artifacts/crystle-hunter-world-v1/public/data/payouts/{payoutId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null &&
        request.auth.token.email == resource.data.recipientEmail;
    }

    // Syndicate (Guild) Security
    match /artifacts/crystle-hunter-world-v1/guilds/{guildId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Refined: leader/member specific in app logic
      allow delete: if request.auth != null && 
        request.auth.token.email == resource.data.leaderId;
      
      // Syndicate Messages (Sub-collection)
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if isAdmin();
      }
    }

    // Syndicate War Security
    match /artifacts/crystle-hunter-world-v1/guild_wars/{warId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
