rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // V2 Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // V2 Helper: Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // V2 Helper: Genesis Admin Check
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'skippergemx@gmail.com';
    }
    
    // --- ULTIMATE PROTOCOL: Admin Override ---
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // --- V2 UNIFIED CORE COLLECTIONS ---

    // 1. Players Collection (Root)
    match /players/{userId} {
      // Anyone authenticated can read player profile for Leaderboards/Guilds
      allow read: if isAuthenticated();
      // Only the owner or Admin can modify their own player data
      allow write: if isOwner(userId);
    }

    // 2. Guilds Collection (Root)
    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Update logic handled by app (joining/leaving), but rules allow auth users
      allow update: if isAuthenticated();
      // Only the leader can delete a guild
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.leaderId);

      // Guild Comms (Sub-collection)
      match /messages/{messageId} {
        allow read, create: if isAuthenticated();
      }
    }

    // 3. Guild Wars (Root)
    match /guild_wars/{warId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 4. PVP Arena Presence (Root)
    match /pvp_room/{userId} {
      allow read: if isAuthenticated();
      // Users can only write their own combat signal
      allow write: if isOwner(userId);
      // Others can update (attack) specific fields like HP/lastHitBy
      allow update: if isAuthenticated();
    }

    // 5. Global Chat (Root)
    match /global_chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // 6. Marketplace (Root)
    match /marketplace/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only seller can delete or update their listing
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.sellerUid);
    }

    // 7. Payouts (Root)
    match /payouts/{payoutId} {
      allow create: if isAuthenticated();
      // Only the recipient can see and claim (delete) their payout
      allow read, delete: if isAuthenticated() && (request.auth.uid == resource.data.recipientUid);
    }

    // --- LEGACY FALLBACKS (For Nuclear Wipe access) ---
    match /artifacts/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    match /users/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
